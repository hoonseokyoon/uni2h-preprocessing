# Copy this file to configs/runpod_wsi.env and fill the values.

# Server/run identity
DB_PATH=/workspace/server_state/runpod_distributed.sqlite
RUN_ID=default
WORKER_TOKEN=replace-with-long-random-token
SERVER_POD_ID=replace-with-server-pod-id
SERVER_PORT=8080

# Docker image used for GPU worker pods
IMAGE_NAME=your-registry/path-rna-fusion-runpod:latest

# RunPod worker creation
RUNPOD_API_KEY=replace-with-runpod-api-key
NETWORK_VOLUME_ID=replace-with-network-volume-id
GPU_TYPE_ID=NVIDIA RTX 6000 Ada Generation
GPU_COUNT=1
HOURLY_COST=1.50
WORKER_COUNT=1
WORKER_NAME_PREFIX=wsi-worker
WORKSPACE_ROOT=/workspace
WORKER_ROLE=wsi-preprocess
# DATA_CENTER_IDS=US-KS-2,US-CA-2

# WSI plan and enqueue
DATASETS=TCGA-UCEC
WSI_QC_POLICY=main_strict
PLAN_DIR=/workspace/manifests/download_plans_v0_wsi_ucec_main_strict
DATA_ROOT=data
MAX_FILES_PER_CHUNK=50
MAX_BYTES_PER_CHUNK=50GB
SOURCE_ADAPTER=gdc
ARTIFACT_ROOT=/workspace/artifacts/wsi_uni2h_v0
UNI2H_CONFIG_PATH=configs/uni2h_w8yi_style.yaml
EXTRACT_SCRIPT=scripts/extract_uni2h_features.py
BATCH_SIZE=128
MAX_ATTEMPTS=2

# Worker-local stage-in controls
LOCAL_WSI_CACHE_DIR=/tmp/wsi_cache
PREFETCH_MAX_BYTES=250GB

# Hugging Face access for gated UNI2-h weights
HF_TOKEN=hf_replace_me

# Export to S3-compatible storage, including MinIO
EXPORT_DESTINATION=s3://my-bucket/path-rna-fusion/wsi_uni2h_v0
EXPORT_ENDPOINT_URL=https://MINIO_ENDPOINT
EXPORT_INVENTORY_PATH=/workspace/manifests/export_inventory_wsi_uni2h_v0.csv
AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key
AWS_DEFAULT_REGION=us-east-1
