# GPU Worker Pod environment.
RUNPOD_MODE=wsi-worker
SERVER_URL=http://SERVER_POD_ID.runpod.internal:8080
RUN_ID=default
WORKER_TOKEN=replace-with-same-token-as-server
WORKSPACE_ROOT=/workspace
LOCAL_WSI_CACHE_DIR=/tmp/wsi_cache

# UNI2-h is gated on Hugging Face. The account must have access approved.
HF_TOKEN=hf_replace_me
WARMUP_UNI2H=1
WARMUP_DEVICE=cpu

# Batch and stage-in controls.
BATCH_JOBS=4
PREFETCH_JOBS=2
PREFETCH_MAX_BYTES=250GB
LEASE_SECONDS=1800
